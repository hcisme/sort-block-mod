{
	"schemaVersion": 1,
	"id": "sort-block-mod",
	"version": "${version}",
	"name": "Sort Block Mod",
	"description": "According to the content on the display board of the box, automatically sort the items.",
	"authors": [
		"hcisme"
	],
	"contact": {
		"homepage": "https://github.com/hcisme/sort-block-mod",
		"sources": "https://github.com/hcisme/sort-block-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/sort-block-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "io.github.hcisme.sortblock.SortBlockMod",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "io.github.hcisme.sortblock.SortBlockModDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"sort-block-mod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}